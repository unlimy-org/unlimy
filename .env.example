BOT_TOKEN=your_bot_token

# Shared PostgreSQL — same credentials as in node-cluster/.env
# In Docker: host is "postgres" (service name from docker-compose)
DATABASE_URL=postgresql://vpn_gateway:vpn_gateway_secret@postgres:5432/vpn_gateway

DEFAULT_LANGUAGE=ru

# VPN Gateway URL — in Docker it's the service name "gateway"
MASTER_NODE_URL=http://gateway:8000
# Must match BOT_API_KEY from node-cluster/.env
MASTER_NODE_API_KEY=replace-with-long-random-token

CONFIG_POLL_INTERVAL_SEC=15

STARS_ENABLED=true

CRYPTOBOT_ENABLED=false
CRYPTOBOT_TOKEN=your_cryptobot_token
CRYPTOBOT_ASSET=USDT
CRYPTOBOT_API_BASE=https://pay.crypt.bot/api

SUPPORT_ADMIN_IDS=123456789,987654321

# Debug: skip payment and go straight to config creation (for testing)
DEBUG_SKIP_PAYMENT=false
